.DS_Store

# Python/R caches
__pycache__/
*.pyc
.pytest_cache/
tests/
test_*.py
.Rhistory
.RData

# Local environments and dependency caches
.conda/
.venv/
renv/library/

# Generated analysis outputs and large objects
analysis/
dist/
seuratv5_environment_check/
seuratv5_r_package_check.tsv
*.rds
*.rda
*.h5ad
*.loom
*.mtx
*.mtx.gz
*.qs

# Logs and temporary files
*.log
tmp/
temp/
docs/superpowers/

# Local MCP runtime mirrors and sandbox data
mcp_server/skill_runtime/
mcp_server/workspace/**
!mcp_server/workspace/
!mcp_server/workspace/code/
!mcp_server/workspace/code/.gitkeep
!mcp_server/workspace/inputs/
!mcp_server/workspace/inputs/.gitkeep
!mcp_server/workspace/logs/
!mcp_server/workspace/logs/.gitkeep
!mcp_server/workspace/logs/.gitignore
!mcp_server/workspace/outputs/
!mcp_server/workspace/outputs/.gitkeep
!mcp_server/workspace/outputs/.gitignore
!mcp_server/workspace/runtime/
!mcp_server/workspace/runtime/.gitkeep
!mcp_server/workspace/runtime/.gitignore
